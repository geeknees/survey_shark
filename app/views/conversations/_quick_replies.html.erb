<%# ABOUTME: Renders state-aware quick-reply chips for conversation input support. %>
<%# ABOUTME: Each chip inserts text into the composer without submitting the form. %>
<% suggestions = quick_reply_suggestions(conversation) %>
<div id="quick_replies" class="space-y-2">
  <div class="text-sm text-gray-600">クイック返信:</div>
  <div class="flex flex-wrap gap-2">
    <% suggestions.each do |suggestion| %>
      <button type="button"
              class="bg-gray-100 text-gray-700 px-3 py-1 rounded-full text-sm hover:bg-gray-200 focus:ring-2 focus:ring-gray-500 focus:ring-offset-2"
              data-action="click->chat-composer#insertQuickReply"
              data-text="<%= suggestion %>">
        <%= suggestion %>
      </button>
    <% end %>
  </div>
</div>
